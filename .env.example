# Database (local / Docker)
DB_USER=aquamanager
DB_PASSWORD=changeme
DB_NAME=aquamanager
DATABASE_URL=postgresql://aquamanager:changeme@localhost:5432/aquamanager

# API
PORT=3333
NODE_ENV=development
JWT_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32!!
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Uploads locais (opcional — padrão: packages/api/uploads)
# UPLOAD_DIR=
MAX_UPLOAD_MB=5

# Web (Vite) — deixe vazio em dev (usa proxy /api → :3333). Em prod/Docker, URL acessível no browser.
# VITE_API_URL=
