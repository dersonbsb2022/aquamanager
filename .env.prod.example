# Produção / Docker Swarm — copie para .env na raiz do projeto no servidor

DB_USER=aquamanager
DB_PASSWORD=troque-por-senha-forte
DB_NAME=aquamanager

# Mínimo 32 caracteres cada
JWT_SECRET=troque-por-segredo-access-com-32-chars-ou-mais
JWT_REFRESH_SECRET=troque-por-segredo-refresh-com-32-chars-ou-mais

MAX_UPLOAD_MB=5
WEB_PORT=80

# Imagens (publicadas pelo GitHub Actions em ghcr.io)
API_IMAGE=ghcr.io/dersonbsb2022/aquamanager-api:latest
WEB_IMAGE=ghcr.io/dersonbsb2022/aquamanager-web:latest

# Deixe vazio: o nginx do frontend faz proxy para a API no mesmo host
# VITE_API_URL=
