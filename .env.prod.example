# Referência de valores para docker-compose.stack.yml (Portainer / Swarm)
#
# O Portainer NÃO usa este arquivo. Copie os valores para o YAML do stack
# (docker-compose.stack.yml), nos campos ALTERE_* e ajuste porta/imagem se precisar.

# postgres.environment
POSTGRES_USER=aquamanager
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=aquamanager

# api.environment — DATABASE_URL deve usar a mesma senha do Postgres
# postgresql://aquamanager:SENHA@postgres:5432/aquamanager
JWT_SECRET=troque-por-segredo-access-com-32-chars-ou-mais
JWT_REFRESH_SECRET=troque-por-segredo-refresh-com-32-chars-ou-mais
MAX_UPLOAD_MB=5

# web.ports — published (host)
WEB_PORT=80

# Imagens GHCR (pacote aquamanager)
# ghcr.io/dersonbsb2022/aquamanager:api-latest
# ghcr.io/dersonbsb2022/aquamanager:web-latest
